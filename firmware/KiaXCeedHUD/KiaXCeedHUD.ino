static uint32_t activeDisplayFingerprint(const Config& value){JsonDocument j;j["brightness"]=value.brightness;j["simulateObd"]=value.simulateObd;j["canListenOnly"]=value.canListenOnly;auto a=j["widgets"].to<JsonArray>();if(activeVirtualDisplay>=0&&activeVirtualDisplay<(int8_t)value.virtualDisplays.size())Config::widgetsToJson(a,value.virtualDisplays[activeVirtualDisplay].widgets);else Config::widgetsToJson(a,value.widgets);String encoded;serializeJson(j,encoded);uint32_t hash=2166136261u;for(size_t i=0;i<encoded.length();i++){hash^=(uint8_t)encoded[i];hash*=16777619u;}return hash;}
static bool vehicleMoving(){return !cfg.simulateObd&&max(telemetry.speedKph,telemetry.gpsSpeedKph)>=1.0f;}
static float conditionMetric(const char*metric){if(!strcmp(metric,"speed"))return telemetry.speedKph;if(!strcmp(metric,"rpm"))return telemetry.rpm;if(!strcmp(metric,"coolant"))return telemetry.coolantC;if(!strcmp(metric,"soc"))return telemetry.soc;if(!strcmp(metric,"load"))return telemetry.engineLoad;if(!strcmp(metric,"voltage"))return telemetry.controlVoltage;return 0;}
static bool displayCondition(const VirtualDisplay&d){if(!d.enabled)return false;if(d.condition==CONDITION_BOOT)return (int32_t)(bootDisplayUntil-millis())>0;if(d.condition==CONDITION_BATTERY)return batteryPowerActive;float value=conditionMetric(d.metric);switch(d.condition){case CONDITION_LT:return value<d.threshold;case CONDITION_LTE:return value<=d.threshold;case CONDITION_GT:return value>d.threshold;case CONDITION_GTE:return value>=d.threshold;case CONDITION_EQ:return fabsf(value-d.threshold)<0.01f;default:return false;}}
static int8_t desiredVirtualDisplay(){for(int i=(int)cfg.virtualDisplays.size()-1;i>=0;i--)if(displayCondition(cfg.virtualDisplays[i]))return i;return -1;}
