static void sendFrameExport(AsyncWebServerRequest*r,bool csv){size_t snapshotHead=frameHead,snapshotCount=frameCount,snapshotCapacity=frameCapacity;auto response=r->beginChunkedResponse(csv?"text/csv":"text/plain",[snapshotHead,snapshotCount,snapshotCapacity,cursor=(size_t)0,csv](uint8_t*buffer,size_t maximum,size_t index)mutable->size_t{size_t used=0;if(csv&&index==0){const char*header="seconds,milliseconds,id,dlc,data,decode\r\n";size_t length=strlen(header);if(length>maximum)return 0;memcpy(buffer,header,length);used=length;}while(cursor<snapshotCount){CanFrame f=frames[(snapshotHead+snapshotCapacity-snapshotCount+cursor)%snapshotCapacity];char row[192],raw[25]={};for(int i=0;i<f.dlc;i++)snprintf(raw+strlen(raw),sizeof(raw)-strlen(raw),"%02X%s",f.data[i],i+1<f.dlc?(csv?" ":""):"");int length;if(csv){auto decoded=obdDescription(f);length=snprintf(row,sizeof(row),"%.3f,%u,%03X,%u,\"%s\",\"%s\"\r\n",f.ms/1000.0,f.ms,(unsigned)f.id,f.dlc,raw,decoded.c_str());}else length=snprintf(row,sizeof(row),"(%u.%03u000) can0 %03X#%s\n",f.ms/1000,f.ms%1000,(unsigned)f.id,raw);if(length<=0||(size_t)length>maximum-used)break;memcpy(buffer+used,row,length);used+=length;cursor++;}return used;});response->addHeader("Content-Disposition",csv?"attachment; filename=kia-hud-2min.csv":"attachment; filename=kia-hud-2min.log");response->addHeader("Cache-Control","no-store");r->send(response);}
static void appendFrameSummary(JsonObject o,const FrameTypeStats&type,const FrameTypeSummary&summary){o["key"]=type.key;o["name"]=(type.latest.id>=0x7E8&&type.latest.id<=0x7EF&&type.latest.dlc>=3)?obdPidName(type.latest.data[2]):"CAN frame";o["count"]=summary.count;o["frequency"]=(summary.count>1&&summary.lastMs>summary.firstMs)?(summary.count-1)*1000.0f/(summary.lastMs-summary.firstMs):0;o["value"]=summary.metric?summary.latest:0;o["min"]=summary.metric?summary.minimum:0;o["max"]=summary.metric?summary.maximum:0;o["realMin"]=type.realMin;o["realMax"]=type.realMax;o["unit"]=type.unit;o["metric"]=summary.metric;char raw[25]={};for(int i=0;i<type.latest.dlc;i++)snprintf(raw+strlen(raw),sizeof(raw)-strlen(raw),"%02X%s",type.latest.data[i],i+1<type.latest.dlc?" ":"");o["raw"]=raw;}
static void sendFrameTypes(AsyncWebServerRequest*r){performance->webBegin(r);uint32_t started=micros();JsonDocument j;auto out=j.to<JsonArray>();uint32_t now=millis();if(frameAnalytics&&frameAnalyticsMutex&&xSemaphoreTake(frameAnalyticsMutex,pdMS_TO_TICKS(10))==pdTRUE){for(size_t i=0;i<FRAME_TYPE_CAPACITY;i++){const auto&type=frameAnalytics->data()[i];if(!type.used)continue;auto summary=frameAnalytics->summarize(type,now);if(summary.count)appendFrameSummary(out.add<JsonObject>(),type,summary);}xSemaphoreGive(frameAnalyticsMutex);}performance->recordAnalysis(micros()-started);sendJson(r,j);}
static void sendFrameDetail(AsyncWebServerRequest*r,const char*key){performance->webBegin(r);uint32_t started=micros();JsonDocument j;uint32_t now=millis();bool found=false;if(frameAnalytics&&frameAnalyticsMutex&&xSemaphoreTake(frameAnalyticsMutex,pdMS_TO_TICKS(10))==pdTRUE){const auto*type=frameAnalytics->find(key);if(type){auto summary=frameAnalytics->summarize(*type,now);if(summary.count){found=true;appendFrameSummary(j.to<JsonObject>(),*type,summary);j["description"]=obdDescription(type->latest);j["windowMs"]=summary.count>1?summary.lastMs-summary.firstMs:0;j["lastChangeMs"]=type->lastChangeMs;j["changeAgeMs"]=type->lastChangeMs?now-type->lastChangeMs:0;auto history=j["history"].to<JsonArray>();uint32_t nowSecond=now/1000;for(int age=(int)FRAME_HISTORY_BUCKETS-1;age>=0;age--){if(nowSecond<(uint32_t)age)continue;uint32_t second=nowSecond-age;const auto&bucket=type->buckets[second%FRAME_HISTORY_BUCKETS];if(bucket.second==second&&bucket.metric){auto point=history.add<JsonObject>();point["ms"]=bucket.lastMs;point["value"]=bucket.latest;}}}}xSemaphoreGive(frameAnalyticsMutex);}performance->recordAnalysis(micros()-started);if(!found){r->send(404,"application/json","{\"error\":\"frame type not found\"}");performance->webEnd(r);return;}sendJson(r,j);}
static void analysisRoutes(){
  server.on("/api/performance",HTTP_GET,[](AsyncWebServerRequest*r){if(!auth(r))return;JsonDocument j;performance->toJson(j);sendJson(r,j);});
  server.on("/api/screenshot.rgb565",HTTP_GET,[](AsyncWebServerRequest*r){if(!auth(r))return;auto response=r->beginResponse("application/octet-stream",DisplayPort::SCREENSHOT_BYTES,[](uint8_t*buffer,size_t maximum,size_t index){return display.readScreenshot(buffer,maximum,index);});response->addHeader("X-Framebuffer-Width","480");response->addHeader("X-Framebuffer-Height","480");response->addHeader("X-Pixel-Format","RGB565-LE");response->addHeader("Cache-Control","no-store");r->send(response);});
  server.on("/api/can-status",HTTP_GET,[](AsyncWebServerRequest*r){if(!auth(r))return;JsonDocument j;j["frameTotal"]=frameTotal;j["ageMs"]=millis()-telemetry.lastCanMs;j["targetFps"]=cfg.simulateObd?SIMULATED_CAN_FPS:0;sendJson(r,j);});
  server.on("/api/pids",HTTP_GET,[](AsyncWebServerRequest*r){if(!auth(r))return;JsonDocument j;auto a=j.to<JsonArray>();for(const auto&d:SAE_PIDS){auto o=a.add<JsonObject>();char pid[3];snprintf(pid,sizeof(pid),"%02X",d.pid);o["pid"]=pid;o["name"]=d.name;o["unit"]=d.unit;o["min"]=d.minimum;o["max"]=d.maximum;o["bytes"]=d.bytes;bool seen=false,supported=false;for(size_t n=0;n<frameCount;n++){auto&f=frames[(frameHead+frameCapacity-frameCount+n)%frameCapacity];if(f.id<0x7E8||f.id>0x7EF||f.dlc<4||f.data[1]!=0x41)continue;if(f.data[2]==d.pid)seen=true;if((f.data[2]%0x20)==0&&f.dlc>=7&&d.pid>f.data[2]&&d.pid<=f.data[2]+32){uint8_t bit=d.pid-f.data[2]-1;supported|=(f.data[3+bit/8]&(0x80>>(bit%8)))!=0;}}o["seen"]=seen;o["supported"]=supported;}sendJson(r,j);});
