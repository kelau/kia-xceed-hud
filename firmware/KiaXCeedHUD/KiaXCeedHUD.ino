  cfgStorage=(Config*)heap_caps_malloc(sizeof(Config),MALLOC_CAP_SPIRAM);
  if(!cfgStorage){Serial.printf("FATAL: PSRAM Config allocation failed (%u bytes)\n",(unsigned)sizeof(Config));return;}
  new(cfgStorage) Config();
  Serial.printf("Config allocated in PSRAM (%u bytes); largest DMA block %u\n",(unsigned)sizeof(Config),(unsigned)heap_caps_get_largest_free_block(MALLOC_CAP_DMA));
  frameCapacity=FRAME_HISTORY_CAPACITY;while(frameCapacity>=30000&&!frames){frames=(CanFrame*)heap_caps_malloc(frameCapacity*sizeof(CanFrame),MALLOC_CAP_SPIRAM);if(!frames)frameCapacity/=2;}Serial.printf("CAN history allocated in PSRAM: %u frames, %u bytes, target %.0f seconds at %u fps\n",(unsigned)frameCapacity,(unsigned)(frameCapacity*sizeof(CanFrame)),frameCapacity/(float)SIMULATED_CAN_FPS,(unsigned)SIMULATED_CAN_FPS);
  configMutex=xSemaphoreCreateMutex();
  cfg.load();bootDisplayUntil=millis()+cfg.virtualDisplays[0].timeoutMs;if(cfg.virtualDisplays[0].enabled)activeVirtualDisplay=0;selectDisplay(activeVirtualDisplay);Serial.printf("Config schema %u loaded\n",CONFIG_SCHEMA_VERSION);
  displayStarted=true;initDisplay();displayConfigApplied=displayConfigRequested;Serial.println("Display and touch initialized");
  Serial.println("Board services initialization deferred until network startup completes");
  initWifi();Serial.println("Wi-Fi stack initialized; temporary AP inactive");
