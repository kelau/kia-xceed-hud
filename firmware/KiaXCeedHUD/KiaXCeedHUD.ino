static void recordFrame(const CanFrame&f){if(!frames||!frameCapacity)return;while(frameCount&&f.ms-frameAt(0).ms>FRAME_HISTORY_MS)frameCount--;if(frameCount==frameCapacity){frameCount--;performance->noteCanCoalesced();}frames[frameHead]=f;frameHead=(frameHead+1)%frameCapacity;frameCount++;if(frameAnalytics&&frameAnalyticsMutex){if(xSemaphoreTake(frameAnalyticsMutex,0)==pdTRUE){uint32_t started=micros();frameAnalytics->record(f);xSemaphoreGive(frameAnalyticsMutex);performance->recordAnalysis(micros()-started);}else performance->noteCanCoalesced();}}
