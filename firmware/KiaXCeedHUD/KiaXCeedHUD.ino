  if(millis()-last>250) {
    last=millis();
    dashboard.update(displayCfg,telemetry,millis());
  }
  if(displayStarted){uint32_t lcdStarted=micros();performance->noteDisplayService(lcdStarted);display.update();performance->recordLcd(micros()-lcdStarted);} delay(2);
  static uint32_t lastMetricsEvent=0,lastFramesEvent=0,lastCanEvent=0,lastPerformanceEvent=0;uint32_t eventNow=millis();
  if(eventNow-lastMetricsEvent>=500){lastMetricsEvent=eventNow;events.send("{}","metrics",eventNow);}
  if(eventNow-lastFramesEvent>=1000){lastFramesEvent=eventNow;events.send("{}","frames",eventNow);}
  if(eventNow-lastCanEvent>=500){lastCanEvent=eventNow;events.send("{}","can",eventNow);}
  if(eventNow-lastPerformanceEvent>=1000){lastPerformanceEvent=eventNow;events.send("{}","performance",eventNow);}
  performance->recordLoop(micros()-loopStarted);performance->tick(millis());
}
